# ── Google Sheets CSV URL ──────────────────────────────────────────────────────
# How to get this URL:
#   1. Open your Google Sheet
#   2. File → Share → Publish to web
#   3. Under "Link", select the sheet tab and choose "Comma-separated values (.csv)"
#   4. Click Publish and copy the URL
#
# The URL will look like:
#   https://docs.google.com/spreadsheets/d/SHEET_ID/pub?gid=0&single=true&output=csv
#
# Leave blank to use the placeholder ward data defined in src/lib/data.js
SHEET_CSV_URL=

# Published Google Sheet CSV URL for the special-events tab
# Same process as above — publish the second tab as CSV and paste the URL here
# Leave blank if you have no upcoming special events
SPECIAL_EVENTS_CSV_URL=
